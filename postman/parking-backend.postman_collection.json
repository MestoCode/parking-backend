                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/admin/nodes/{{nodeId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "nodes",
                "{{nodeId}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Attach Node To Zone",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{internalAccessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"zoneId\": \"{{zoneId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/nodes/{{nodeId}}/zone",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "nodes",
                "{{nodeId}}",
                "zone"
              ]
            }
          },
          "response": []
        },
        {
          "name": "List Nodes In Zone",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{internalAccessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/admin/zones/{{zoneId}}/nodes",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "zones",
                "{{zoneId}}",
                "nodes"
              ]
            }
          },
          "response": []
        }
