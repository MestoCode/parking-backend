    },
    {
      "name": "Device and MQTT Auth",
      "description": "Device-facing authentication endpoints already present in the backend.",
      "item": [
        {
          "name": "Authenticate Device",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Device auth succeeded', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json.accessToken) {",
                  "  pm.environment.set('deviceAccessToken', json.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"deviceId\": \"{{deviceId}}\",\n  \"deviceSecret\": \"{{deviceSecret}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/device",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "device"
              ]
            },
            "description": "Authenticates an ESP/device and saves `deviceAccessToken`."
          },
          "response": []
        },
        {
          "name": "Validate MQTT Connection",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{deviceId}}\",\n  \"password\": \"{{deviceAccessToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/mqtt",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "mqtt"
              ]
            },
            "description": "Validates MQTT username/password where password is the device JWT."
          },
          "response": []
        }
      ]
    }
